ដើម្បីទៅទីនោះនៅថ្ងៃស្អែក
ដើម្បីពិនិត្យមើលវាចេញ។

51
00:04:01,470 --> 00:04:02,840
មើល វានៅទីនេះ។

52
00:04:03,360 --> 00:04:04,240
បើ

53
00:04:04,240 --> 00:04:06,120
មាត្រដ្ឋាន និងទីតាំងដំណើរការបានល្អ

54
00:04:06,120 --> 00:04:07,400
ខ្ញុំចង់ដាក់ពាក្យ
ទៅសណ្ឋាគារ

55
00:04:07,400 --> 00:04:09,190
សម្រាប់ការបញ្ចុះតម្លៃពិសេសសម្រាប់អ្នកប្រឡង។

56
00:04:09,190 --> 00:04:10,400
នោះពិតជាអស្ចារ្យណាស់!

57
00:04:10,630 --> 00:04:11,960
យកខ្ញុំទៅជាមួយអ្នក។

58
00:04:11,960 --> 00:04:14,030
ខ្ញុំចង់ពង្រីកកន្លែងប្រឡង
សម្រាប់បងប្អូនជីដូនមួយរបស់ខ្ញុំផងដែរ។

59
00:04:14,030 --> 00:04:14,680
កិច្ចព្រមព្រៀង។

60
00:04:22,800 --> 00:04:23,630
នៅទីនេះយើង។

61
00:04:23,700 --> 00:04:28,310
[សាលាហិរញ្ញវត្ថុ និងសេដ្ឋកិច្ចស៊ីនហួ
ការិយាល័យសេវាប៉ូលីស]

62
00:04:26,800 --> 00:04:28,510
វាយកតែយើង

63
00:04:28,370 --> 00:04:30,990
[កំណត់ម៉ោង]

64
00:04:28,920 --> 00:04:30,000
ដប់មួយនាទីនៅលើជើង
ពីកន្លែងទទួលភ្ញៀវសណ្ឋាគារ

65
00:04:30,000 --> 00:04:31,190
ដើម្បីទៅដល់ទីនេះ។

66
00:04:31,190 --> 00:04:31,950
